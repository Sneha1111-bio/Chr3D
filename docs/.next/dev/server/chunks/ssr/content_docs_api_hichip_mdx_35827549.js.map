import {Fragment as _Fragment, jsx as _jsx, jsxs as _jsxs} from "react/jsx-runtime";
export let _markdown = "\n\n# HiChIP Python API\n\nComplete Python API for analyzing HiChIP (Hi-C + ChIP) data for protein-centric chromatin interaction mapping.\n\n## Overview\n\n**Important**: HiChIP does **NOT** use linker sequences. Unlike ChIA-PET, HiChIP uses biotinylated nucleotides incorporated during fill-in after restriction digestion.\n\nHiChIP analysis requires these modules:\n\n* `PETMapper` - Read mapping (no linker filtering)\n* `HiChIPPurifier` - Restriction fragment-based purification\n* `PETCategorizer` - PET classification\n* `PeakCaller` - Peak calling from sPET\n* `PreClusterer`, `AnchorClusterer`, `StatisticalSignificance` - Loop calling with distance correction\n\n## Complete Pipeline Example\n\n```python\nimport sys\nsys.path.insert(0, '/path/to/Chr3D/src')\n\nfrom pathlib import Path\nfrom chr3d.mapping_v2 import PETMapper\nfrom chr3d.hichip_purifying import HiChIPPurifier\nfrom chr3d.pet_categorization import PETCategorizer\nfrom chr3d.peak_calling import PeakCaller\nfrom chr3d.loop_calling import PreClusterer, AnchorClusterer, StatisticalSignificance\n\n# Configuration\nfastq_r1 = \"/data/H3K27ac_HiChIP_R1.fastq.gz\"\nfastq_r2 = \"/data/H3K27ac_HiChIP_R2.fastq.gz\"\ngenome_index = \"/ref/hg38.fa\"\nrestriction_sites = \"/ref/hg38_MboI_sites.bed\"\noutput_dir = Path(\"/output/hichip_analysis\")\noutput_dir.mkdir(parents=True, exist_ok=True)\n\n# =============================================================================\n# STEP 1: SKIPPED - HiChIP does NOT use linkers\n# =============================================================================\n# Unlike ChIA-PET, HiChIP reads are mapped directly without linker filtering\n\n# =============================================================================\n# STEP 2: GENOMIC MAPPING\n# =============================================================================\nmapper = PETMapper(\n    genome_index=genome_index,\n    mapping_quality_cutoff=30,\n    n_threads=8,\n    use_bwa_mem=True,  # Recommended for HiChIP\n    self_ligation_cutoff=8000\n)\n\nmap_stats = mapper.map_linker_filtered_fastq(\n    fastq_r1=fastq_r1,\n    fastq_r2=fastq_r2,\n    output_prefix='mapped',\n    output_dir=str(output_dir / 'step2_mapping'),\n    keep_sam=False,\n    remove_duplicates=True\n)\n\nprint(f\"Total PETs: {map_stats.get('total_pets', 'N/A')}\")\nprint(f\"Unique PETs: {map_stats.get('unique_pets', 'N/A')}\")\n\nbedpe_file = str(output_dir / 'step2_mapping/mapped.dedup.bedpe')\n\n# =============================================================================\n# STEP 3: PET PURIFYING (Restriction Fragment Filtering)\n# =============================================================================\n# Remove same-fragment PETs (invalid ligation products)\npurifier = HiChIPPurifier(restriction_file=restriction_sites)\n\npurified_bedpe = str(output_dir / 'step3_purifying/purified.valid.bedpe')\nsameres_bedpe = str(output_dir / 'step3_purifying/purified.sameres.bedpe')\n\npurify_stats = purifier.remove_same_fragment_pets(\n    bedpe_file,\n    purified_bedpe,\n    sameres_bedpe\n)\n\nprint(f\"Valid PETs: {purify_stats.get('valid_pets', 'N/A')}\")\nprint(f\"Same-fragment removed: {purify_stats.get('same_fragment_pets', 'N/A')}\")\n\n# =============================================================================\n# STEP 4: PET CATEGORIZATION\n# =============================================================================\ncategorizer = PETCategorizer(\n    self_ligation_cutoff=1000,  # 1kb for HiChIP (shorter than ChIA-PET)\n    mode='hichip'\n)\n\ncat_stats = categorizer.categorize_bedpe(\n    purified_bedpe,\n    str(output_dir / 'step4_categorization/categorized')\n)\n\nprint(f\"iPETs: {cat_stats['ipet']['count']:,} ({cat_stats['ipet']['percentage']:.1f}%)\")\nprint(f\"sPETs: {cat_stats['spet']['count']:,} ({cat_stats['spet']['percentage']:.1f}%)\")\n\nipet_file = str(output_dir / 'step4_categorization/categorized.ipet')\nspet_file = str(output_dir / 'step4_categorization/categorized.spet')\n\n# =============================================================================\n# STEP 5: PEAK CALLING\n# =============================================================================\npeak_caller = PeakCaller(\n    genome_size='hs',\n    qvalue_cutoff=0.05,\n    keep_dup='all'\n)\n\npeak_stats = peak_caller.call_peaks(\n    spet_file,\n    str(output_dir / 'step5_peaks/peaks')\n)\n\nprint(f\"Peaks called: {peak_stats.get('num_peaks', 0):,}\")\n\n# =============================================================================\n# STEP 6: LOOP CALLING WITH DISTANCE CORRECTION\n# =============================================================================\n\n# Step 6.1: Pre-clustering\npre_clusterer = PreClusterer(extension_length=500)\nprecluster_stats = pre_clusterer.pre_cluster(\n    ipet_file,\n    str(output_dir / 'step6_loops/preclustered')\n)\n\nprint(f\"Pre-clusters: {precluster_stats.get('cluster_count', 0):,}\")\n\n# Step 6.2: Anchor clustering\nanchor_clusterer = AnchorClusterer()\ncluster_stats = anchor_clusterer.cluster_anchors(\n    precluster_stats['output_file'],\n    str(output_dir / 'step6_loops/clusters.txt')\n)\n\nprint(f\"Anchor clusters: {cluster_stats.get('total_anchor_clusters', 0):,}\")\n\n# Step 6.3: Statistical significance with DISTANCE CORRECTION\n# HiChIP requires distance correction due to proximity ligation bias\nstat_sig = StatisticalSignificance(\n    ipet_count_threshold=2,\n    pvalue_cutoff=0.05,\n    extension_length=500,\n    use_distance_correction=True  # IMPORTANT: Enable for HiChIP\n)\n\nsig_stats = stat_sig.calculate_significance(\n    str(output_dir / 'step6_loops/clusters.txt'),\n    ipet_file,\n    str(output_dir / 'step6_loops/loops')\n)\n\nprint(f\"Total loops tested: {sig_stats.get('total_loops', 0):,}\")\nprint(f\"Significant loops (FDR < 0.05): {sig_stats.get('significant_loops', 0):,}\")\n```\n\n## Module Reference\n\n### PETMapper\n\nBWA-based read mapping with BEDPE generation.\n\n```python\nfrom chr3d.mapping_v2 import PETMapper\n\nmapper = PETMapper(\n    genome_index: str,                    # BWA-indexed genome FASTA\n    mapping_quality_cutoff: int = 30,     # Minimum MAPQ\n    n_threads: int = 1,                   # Number of threads\n    use_bwa_mem: bool = True,             # Use BWA-MEM (recommended for HiChIP)\n    self_ligation_cutoff: int = 8000      # Self-ligation distance cutoff\n)\n\nstats = mapper.map_linker_filtered_fastq(\n    fastq_r1: str,                        # Input R1 FASTQ\n    fastq_r2: str,                        # Input R2 FASTQ\n    output_prefix: str,                   # Output file prefix\n    output_dir: str = None,               # Output directory\n    keep_sam: bool = False,               # Keep SAM files\n    remove_duplicates: bool = True        # Remove PCR duplicates\n) -> Dict\n```\n\n**Returns:**\n\n```python\n{\n    'total_pets': int,\n    'unique_pets': int,\n    'duplicate_rate': float,\n    'cis_ratio': float,\n    'trans_ratio': float\n}\n```\n\n### HiChIPPurifier\n\nRemoves same-fragment PETs using restriction site information.\n\n```python\nfrom chr3d.hichip_purifying import HiChIPPurifier\n\npurifier = HiChIPPurifier(\n    restriction_file: str    # BED file with restriction sites\n)\n\nstats = purifier.remove_same_fragment_pets(\n    input_bedpe: str,        # Input BEDPE file\n    output_valid: str,       # Output valid PETs\n    output_sameres: str      # Output same-fragment PETs (removed)\n) -> Dict\n```\n\n**Returns:**\n\n```python\n{\n    'total_pets': int,\n    'valid_pets': int,\n    'same_fragment_pets': int,\n    'valid_ratio': float\n}\n```\n\n**Why This Step is Critical:**\n\n* Same-fragment PETs are artifacts from self-ligation\n* Valid PETs must span different restriction fragments\n* This is unique to HiChIP (ChIA-PET uses merge-based purification)\n\n### PETCategorizer\n\nClassifies PETs into iPET, sPET, and oPET categories.\n\n```python\nfrom chr3d.pet_categorization import PETCategorizer\n\ncategorizer = PETCategorizer(\n    self_ligation_cutoff: int = 1000,  # 1kb for HiChIP (vs 8kb for ChIA-PET)\n    mode: str = 'hichip'               # 'hichip' or 'chiapet'\n)\n\nstats = categorizer.categorize_bedpe(\n    input_bedpe: str,\n    output_prefix: str\n) -> Dict\n```\n\n**Returns:**\n\n```python\n{\n    'total': int,\n    'ipet': {'count': int, 'percentage': float},\n    'spet': {'count': int, 'percentage': float},\n    'opet': {'count': int, 'percentage': float},\n    'cis': {'count': int, 'percentage': float},\n    'trans': {'count': int, 'percentage': float}\n}\n```\n\n### PeakCaller\n\nMACS3-based peak calling from self-ligation PETs.\n\n```python\nfrom chr3d.peak_calling import PeakCaller\n\ncaller = PeakCaller(\n    genome_size: str = 'hs',       # 'hs', 'mm', or number\n    qvalue_cutoff: float = 0.05,   # Q-value threshold\n    keep_dup: str = 'all'          # Duplicate handling\n)\n\nstats = caller.call_peaks(\n    input_file: str,               # sPET file\n    output_prefix: str             # Output prefix\n) -> Dict\n```\n\n### Loop Calling Classes\n\n#### PreClusterer\n\n```python\nfrom chr3d.loop_calling import PreClusterer\n\nclusterer = PreClusterer(\n    extension_length: int = 500,        # Tag extension (bp)\n    chrom_sizes_file: str = None        # Optional chromosome sizes\n)\n\nstats = clusterer.pre_cluster(\n    ipet_file: str,\n    output_prefix: str\n) -> Dict\n```\n\n#### AnchorClusterer\n\n```python\nfrom chr3d.loop_calling import AnchorClusterer\n\nclusterer = AnchorClusterer()\n\nstats = clusterer.cluster_anchors(\n    precluster_file: str,\n    output_file: str\n) -> Dict\n```\n\n#### StatisticalSignificance\n\n```python\nfrom chr3d.loop_calling import StatisticalSignificance\n\nsig = StatisticalSignificance(\n    ipet_count_threshold: int = 2,         # Min iPET count\n    pvalue_cutoff: float = 0.05,           # P-value threshold\n    extension_length: int = 500,           # Extension for counting\n    use_distance_correction: bool = True   # ENABLE for HiChIP!\n)\n\nstats = sig.calculate_significance(\n    cluster_file: str,\n    ipet_file: str,\n    output_prefix: str\n) -> Dict\n```\n\n**Distance Correction:**\nHiChIP data has inherent distance bias due to proximity ligation. The `use_distance_correction=True` parameter applies a distance-dependent expected value model to correct for this bias.\n\n## Generating Restriction Sites\n\nBefore running HiChIP analysis, generate the restriction sites file:\n\n```python\nfrom chr3d.restriction_sites import RestrictionSiteGenerator\n\ngenerator = RestrictionSiteGenerator(\n    genome_fasta='/ref/hg38.fa',\n    enzyme='MboI'  # or 'DpnII', 'HindIII', etc.\n)\n\ngenerator.generate(output_file='/ref/hg38_MboI_sites.bed')\n```\n\nOr use CLI:\n\n```bash\nchr3d generate-sites --genome /ref/hg38.fa --enzyme MboI --output /ref/hg38_MboI_sites.bed\n```\n\n## Output Files\n\n| File                            | Description                 |\n| ------------------------------- | --------------------------- |\n| `mapped.dedup.bedpe`            | Deduplicated mapped PETs    |\n| `purified.valid.bedpe`          | Valid inter-fragment PETs   |\n| `purified.sameres.bedpe`        | Removed same-fragment PETs  |\n| `categorized.ipet`              | Inter-ligation PETs         |\n| `categorized.spet`              | Self-ligation PETs          |\n| `peaks_peaks.narrowPeak`        | Called peaks                |\n| `loops.cluster.filtered`        | All loops meeting threshold |\n| `loops.cluster.FDRfiltered.txt` | Significant loops           |\n\n## HiChIP vs ChIA-PET Differences\n\n| Feature            | HiChIP             | ChIA-PET          |\n| ------------------ | ------------------ | ----------------- |\n| Linker filtering   | **No**             | Yes               |\n| Restriction enzyme | Yes (MboI/DpnII)   | No                |\n| Purification       | Fragment-based     | Merge-based       |\n| Distance cutoff    | 1kb                | 8kb               |\n| Statistical model  | Distance-corrected | Standard Poisson  |\n| Input requirement  | Low (1M cells)     | High (100M cells) |\n\n## Quality Metrics\n\n**Good HiChIP Data:**\n\n* Mapping rate: >70%\n* Cis ratio: >60%\n* Valid PET ratio (after purification): >50%\n* iPET percentage: >40%\n\n**Warning Signs:**\n\n* Low cis ratio (\\<40%): May indicate ligation issues\n* High same-fragment rate (>50%): Incomplete digestion\n* Few peaks: Low enrichment or wrong antibody\n";
