export let _markdown = "\n\n## Complete HiChIP Analysis Workflow\n\nThis tutorial demonstrates end-to-end HiChIP data analysis using Chr3D.\n\n## Load Data\n\n```python\nfrom chr3d import HiChIP\n\nhichip = HiChIP.from_pairs(\"GM12878_H3K27ac_HiChIP.pairs.gz\")\n```\n\n## Quality Control\n\n```python\nqc = hichip.qc_report()\nprint(f\"Enrichment: {qc['enrichment']:.2f}x\")\nprint(f\"Long-range: {qc['long_range_percent']:.1f}%\")\n```\n\n## Filter Data\n\n```python\nfiltered = hichip.filter_pairs(min_mapq=30, remove_duplicates=True)\nfiltered = filtered.filter_distance(min_distance=5000, max_distance=2000000)\n```\n\n## Call Loops\n\n```python\nloops = filtered.call_loops(method=\"hichipper\", fdr=0.01)\n```\n\n## Annotate with Peaks\n\n```python\nfrom chr3d.utils import load_peaks\n\npeaks = load_peaks(\"H3K27ac_peaks.bed\")\nloops = loops.annotate_peaks(peaks=peaks, peak_type=\"H3K27ac\")\n```\n\n## Export Results\n\n```python\nloops.to_bedpe(\"loops_annotated.bedpe\")\nhichip.to_cooler(\"output.cool\", resolution=10000)\n```\n\nSee [API reference](../api/hichip) for detailed method documentation.\n";
