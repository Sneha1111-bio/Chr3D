import {Fragment as _Fragment, jsx as _jsx, jsxs as _jsxs} from "react/jsx-runtime";
export let _markdown = "\n\n## Complete Hi-C Analysis Workflow\n\nThis tutorial demonstrates comprehensive Hi-C data analysis using Chr3D.\n\n## Load Data\n\n```python\nfrom chr3d import HiC\n\nhic = HiC.from_cooler(\"K562_HiC.mcool::resolutions/10000\")\n```\n\n## Quality Control\n\n```python\nqc = hic.qc_report()\nprint(f\"Valid pairs: {qc['valid_pairs_pct']:.1f}%\")\nprint(f\"Cis/Trans: {qc['cis_trans_ratio']:.2f}\")\n```\n\n## Normalize\n\n```python\nhic_norm = hic.normalize(method=\"ICE\")\n```\n\n## Call Features\n\n```python\n# Compartments\ncompartments = hic_norm.call_compartments(resolution=100000)\n\n# TADs\ntads = hic_norm.call_tads(method=\"insulation\", window=500000)\n\n# Loops\nloops = hic_norm.call_loops(method=\"hiccups\", fdr=0.1)\n```\n\n## Validate Loops\n\n```python\napa = hic_norm.compute_apa(loops=loops)\nprint(f\"APA score: {apa['score']:.2f}\")\n```\n\n## Export Results\n\n```python\ntads.to_bed(\"tads.bed\")\nloops.to_bedpe(\"loops.bedpe\")\ncompartments.to_bedgraph(\"compartments.bedgraph\")\nhic_norm.to_hic(\"output.hic\", resolutions=[10000, 25000])\n```\n\nSee [API reference](../api/hic) for detailed method documentation.\n";
export let frontmatter = {
