import {Fragment as _Fragment, jsx as _jsx, jsxs as _jsxs} from "react/jsx-runtime";
export let _markdown = "\n\n# HiChIP Analysis with Python API\n\nThis tutorial provides a comprehensive, step-by-step guide to analyzing HiChIP data using the Chr3D Python API. You'll learn exactly what each step does, which classes are used, and what output to expect.\n\n## Pipeline Overview\n\n```mermaid\nflowchart TD\n    subgraph Input[\"📁 Input\"]\n        FASTQ1[R1.fastq.gz]\n        FASTQ2[R2.fastq.gz]\n        GENOME[hg38.fa]\n        RESTRICT[MboI_sites.bed]\n    end\n\n    subgraph Step2[\"Step 2: Mapping\"]\n        MAP[PETMapper]\n        MAP --> BEDPE[mapped.dedup.bedpe]\n    end\n\n    subgraph Step3[\"Step 3: Purifying\"]\n        PURIFY[HiChIPPurifier]\n        PURIFY --> VALID[purified.valid.bedpe]\n        PURIFY --> SAMERES[purified.sameres.bedpe]\n    end\n\n    subgraph Step4[\"Step 4: Categorization\"]\n        CAT[PETCategorizer]\n        CAT --> IPET[categorized.ipet]\n        CAT --> SPET[categorized.spet]\n    end\n\n    subgraph Step5[\"Step 5: Peak Calling\"]\n        PEAKS[PeakCaller]\n        PEAKS --> NARROWPEAK[peaks.narrowPeak]\n    end\n\n    subgraph Step6[\"Step 6: Loop Calling\"]\n        PRE[PreClusterer]\n        ANCHOR[AnchorClusterer]\n        STAT[StatisticalSignificance]\n        PRE --> ANCHOR --> STAT\n        STAT --> LOOPS[loops.FDRfiltered.txt]\n    end\n\n    FASTQ1 --> MAP\n    FASTQ2 --> MAP\n    GENOME --> MAP\n    BEDPE --> PURIFY\n    RESTRICT --> PURIFY\n    VALID --> CAT\n    SPET --> PEAKS\n    IPET --> PRE\n\n    style Input fill:#e8f5e9\n    style Step2 fill:#e3f2fd\n    style Step3 fill:#fff3e0\n    style Step4 fill:#fce4ec\n    style Step5 fill:#f3e5f5\n    style Step6 fill:#e0f7fa\n```\n\n## Source Code Locations\n\n| Class                     | File Location                       | Purpose                            |\n| ------------------------- | ----------------------------------- | ---------------------------------- |\n| `PETMapper`               | `src/chr3d/mapping_v2.py:187`       | BWA alignment and BEDPE generation |\n| `HiChIPPurifier`          | `src/chr3d/hichip_purifying.py:43`  | Remove same-fragment PETs          |\n| `PETCategorizer`          | `src/chr3d/pet_categorization.py:1` | Classify PETs into iPET/sPET/oPET  |\n| `PeakCaller`              | `src/chr3d/peak_calling.py:1`       | MACS3 peak calling                 |\n| `PreClusterer`            | `src/chr3d/loop_calling.py:141`     | Initial tag clustering             |\n| `AnchorClusterer`         | `src/chr3d/loop_calling.py:708`     | Merge overlapping clusters         |\n| `StatisticalSignificance` | `src/chr3d/loop_calling.py:943`     | FDR-corrected significance         |\n\n## Output Directory Structure\n\nAfter running the complete pipeline, your output directory will look like this:\n\n```\noutput_dir/\n├── step2_mapping/\n│   ├── mapped.sam                    # Raw alignment (deleted if cleanup)\n│   ├── mapped.sorted.bam             # Sorted BAM\n│   ├── mapped.dedup.bedpe            # Deduplicated PETs (11 columns)\n│   └── mapping_stats.txt             # Alignment statistics\n│\n├── step3_purifying/\n│   ├── purified.valid.bedpe          # Valid inter-fragment PETs (13 columns)\n│   └── purified.sameres.bedpe        # Removed same-fragment PETs\n│\n├── step4_categorization/\n│   ├── categorized.ipet              # Inter-ligation PETs (11 columns)\n│   ├── categorized.spet              # Self-ligation PETs\n│   └── categorized.opet              # Other PETs\n│\n├── step5_peaks/\n│   ├── peaks_peaks.narrowPeak        # Called peaks\n│   ├── peaks_summits.bed             # Peak summits\n│   └── peaks_peaks.xls               # Peak statistics\n│\n├── step6_loops/\n│   ├── preclustered.pre_cluster.sorted  # Pre-clusters\n│   ├── clusters.txt                     # Anchor clusters\n│   ├── loops.cluster.filtered           # All loops meeting threshold\n│   └── loops.cluster.FDRfiltered.txt    # Significant loops (final output)\n│\n└── pipeline.log                      # Complete pipeline log\n```\n\n***\n\n## Step-by-Step Tutorial\n\n### Prerequisites\n\n```python\nimport sys\nimport logging\nfrom pathlib import Path\n\n# Add Chr3D to path (if not installed)\nsys.path.insert(0, '/path/to/Chr3D/src')\n\n# Setup logging\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n)\n\n# Import Chr3D modules\nfrom chr3d.mapping_v2 import PETMapper\nfrom chr3d.hichip_purifying import HiChIPPurifier\nfrom chr3d.pet_categorization import PETCategorizer\nfrom chr3d.peak_calling import PeakCaller\nfrom chr3d.loop_calling import PreClusterer, AnchorClusterer, StatisticalSignificance\n```\n\n### Configuration\n\n```python\n# Input files\nfastq_r1 = \"/data/H3K27ac_HiChIP_R1.fastq.gz\"\nfastq_r2 = \"/data/H3K27ac_HiChIP_R2.fastq.gz\"\ngenome_index = \"/ref/hg38.fa\"\nrestriction_sites = \"/ref/hg38_MboI_sites.bed\"\n\n# Output directory\noutput_dir = Path(\"/output/hichip_analysis\")\noutput_dir.mkdir(parents=True, exist_ok=True)\n\n# Create step directories\nfor step in ['step2_mapping', 'step3_purifying', 'step4_categorization', \n             'step5_peaks', 'step6_loops']:\n    (output_dir / step).mkdir(exist_ok=True)\n\n# Parameters\nthreads = 8\nsample_id = \"H3K27ac_HiChIP\"\n```\n\n***\n\n## Step 1: Skipped (No Linker Filtering)\n\n**Important**: HiChIP does NOT use linker sequences. Unlike ChIA-PET, HiChIP uses biotinylated nucleotides during fill-in after restriction digestion. Therefore, we skip directly to mapping.\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│  HiChIP vs ChIA-PET: Key Difference                             │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  ChIA-PET:  Read ──[LINKER]── Read                              │\n│             ↓                                                    │\n│             Linker filtering required                            │\n│                                                                  │\n│  HiChIP:    Read ────────── Read                                │\n│             ↓                                                    │\n│             Direct mapping (no linker)                           │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n```\n\n***\n\n## Step 2: Genomic Mapping\n\n### What This Step Does\n\nThe `PETMapper` class aligns paired-end reads to the reference genome using BWA-MEM, then converts alignments to BEDPE format with deduplication.\n\n### ASCII Diagram: Mapping Process\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│                    STEP 2: MAPPING                               │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  R1.fastq.gz ─┐                                                 │\n│               ├──► BWA-MEM ──► SAM ──► Sort ──► BAM             │\n│  R2.fastq.gz ─┘      │                          │               │\n│                      │                          │               │\n│                      ▼                          ▼               │\n│              Alignment Stats          Mark Duplicates           │\n│                                              │                  │\n│                                              ▼                  │\n│                                    Parse to BEDPE               │\n│                                              │                  │\n│                                              ▼                  │\n│                                    mapped.dedup.bedpe           │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n\nBEDPE Format (11 columns):\n┌──────┬────────┬──────┬──────┬────────┬──────┬──────┬───────┬─────────┬─────────┬────────┐\n│ chr1 │ start1 │ end1 │ chr2 │ start2 │ end2 │ name │ score │ strand1 │ strand2 │ mapq   │\n├──────┼────────┼──────┼──────┼────────┼──────┼──────┼───────┼─────────┼─────────┼────────┤\n│ chr1 │ 100000 │100150│ chr1 │ 200000 │200150│ read1│   60  │    +    │    -    │   30   │\n└──────┴────────┴──────┴──────┴────────┴──────┴──────┴───────┴─────────┴─────────┴────────┘\n```\n\n### Code\n\n```python\n# =============================================================================\n# STEP 2: GENOMIC MAPPING\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 2: GENOMIC MAPPING\")\nprint(\"=\" * 70)\n\n# Initialize mapper\nmapper = PETMapper(\n    genome_index=genome_index,\n    mapping_quality_cutoff=30,    # Filter low-quality alignments\n    n_threads=threads,\n    use_bwa_mem=True,             # Recommended for HiChIP\n    self_ligation_cutoff=8000     # Distance cutoff for self-ligation\n)\n\n# Run mapping\nmap_stats = mapper.map_linker_filtered_fastq(\n    fastq_r1=fastq_r1,\n    fastq_r2=fastq_r2,\n    output_prefix='mapped',\n    output_dir=str(output_dir / 'step2_mapping'),\n    keep_sam=False,               # Delete SAM after conversion\n    remove_duplicates=True        # Remove PCR duplicates\n)\n\n# Print statistics\nprint(f\"Total read pairs: {map_stats.get('total_pets', 'N/A'):,}\")\nprint(f\"Mapped pairs: {map_stats.get('mapped_pets', 'N/A'):,}\")\nprint(f\"Unique PETs: {map_stats.get('unique_pets', 'N/A'):,}\")\nprint(f\"Duplicate rate: {map_stats.get('duplicate_rate', 0)*100:.1f}%\")\n\nbedpe_file = str(output_dir / 'step2_mapping/mapped.dedup.bedpe')\n```\n\n### Expected Output\n\n```\nSTEP 2: GENOMIC MAPPING\n======================================================================\nPETMapper initialized\n  Genome index: /ref/hg38.fa\n  Mapping quality cutoff: 30\n  Threads: 8\n  Use BWA-MEM: True\nRunning BWA-MEM alignment...\n  Aligned 100,000 read pairs\n  Converting SAM to BEDPE...\n  Removing duplicates...\nTotal read pairs: 100,000\nMapped pairs: 95,234\nUnique PETs: 78,456\nDuplicate rate: 17.6%\n```\n\n***\n\n## Step 3: PET Purifying (Restriction Fragment Filtering)\n\n### What This Step Does\n\nThe `HiChIPPurifier` removes same-fragment PETs using restriction site information. Same-fragment PETs are artifacts from self-ligation that don't represent real chromatin interactions.\n\n### ASCII Diagram: Purification Logic\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│                    STEP 3: PURIFYING                             │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  Restriction Sites (MboI):                                       │\n│  ────┬────────┬────────┬────────┬────────┬────────              │\n│      │  Frag1 │  Frag2 │  Frag3 │  Frag4 │  Frag5               │\n│      │        │        │        │        │                       │\n│                                                                  │\n│  For each PET:                                                   │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │ Read1 ────────────────────────────────── Read2          │    │\n│  │   │                                         │           │    │\n│  │   ▼                                         ▼           │    │\n│  │ Assign to Fragment                  Assign to Fragment  │    │\n│  │   │                                         │           │    │\n│  │   └──────────── Compare ────────────────────┘           │    │\n│  │                    │                                    │    │\n│  │         ┌──────────┴──────────┐                         │    │\n│  │         ▼                     ▼                         │    │\n│  │   Same Fragment?        Different Fragment?             │    │\n│  │         │                     │                         │    │\n│  │         ▼                     ▼                         │    │\n│  │   REMOVE (artifact)     KEEP (valid)                    │    │\n│  │   → sameres.bedpe       → valid.bedpe                   │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n\nExample:\n┌─────────────────────────────────────────────────────────────────┐\n│ Fragment 1    Fragment 2    Fragment 3    Fragment 4            │\n│ [────────]    [────────]    [────────]    [────────]            │\n│                                                                  │\n│ PET A: R1─────────────────────────────────R2  ✓ VALID           │\n│        (Frag1)                        (Frag3)                    │\n│                                                                  │\n│ PET B: R1────R2                               ✗ SAME-FRAGMENT   │\n│        (Frag2)(Frag2)                                            │\n└─────────────────────────────────────────────────────────────────┘\n```\n\n### Code\n\n```python\n# =============================================================================\n# STEP 3: PET PURIFYING (Restriction Fragment Filtering)\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 3: PET PURIFYING\")\nprint(\"=\" * 70)\n\n# Initialize purifier with restriction sites\npurifier = HiChIPPurifier(restriction_file=restriction_sites)\n\n# Define output files\npurified_bedpe = str(output_dir / 'step3_purifying/purified.valid.bedpe')\nsameres_bedpe = str(output_dir / 'step3_purifying/purified.sameres.bedpe')\n\n# Run purification\npurify_stats = purifier.remove_same_fragment_pets(\n    bedpe_file,           # Input from Step 2\n    purified_bedpe,       # Valid PETs output\n    sameres_bedpe         # Removed same-fragment PETs\n)\n\n# Print statistics\nprint(f\"Total PETs: {purify_stats.get('total_pets', 'N/A'):,}\")\nprint(f\"Valid PETs: {purify_stats.get('valid_pets', 'N/A'):,}\")\nprint(f\"Same-fragment removed: {purify_stats.get('same_fragment_pets', 'N/A'):,}\")\nprint(f\"Valid ratio: {purify_stats.get('valid_ratio', 0)*100:.1f}%\")\n```\n\n### Expected Output\n\n```\nSTEP 3: PET PURIFYING\n======================================================================\nHiChIPPurifier initialized\n  Restriction file: /ref/hg38_MboI_sites.bed\n  Loaded 1,234,567 restriction fragments\nProcessing PETs...\n  Assigning reads to fragments...\nTotal PETs: 78,456\nValid PETs: 43,492\nSame-fragment removed: 34,964\nValid ratio: 55.4%\n```\n\n***\n\n## Step 4: PET Categorization\n\n### What This Step Does\n\nThe `PETCategorizer` classifies PETs into three categories based on genomic distance:\n\n* **iPET (Inter-ligation)**: Long-range interactions (distance > cutoff)\n* **sPET (Self-ligation)**: Short-range/same-fragment (distance ≤ cutoff)\n* **oPET (Other)**: Wrong orientation or unmapped\n\n### ASCII Diagram: Categorization Logic\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│                    STEP 4: CATEGORIZATION                        │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  Distance Calculation:                                           │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  Read1 (chr1:100000)              Read2 (chr1:150000)   │    │\n│  │     │                                  │                │    │\n│  │     └──────── Distance = 50,000 bp ────┘                │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Classification Rules (HiChIP: cutoff = 1000bp):                │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  Distance &gt; 1000bp AND same chromosome?                  │    │\n│  │      YES → iPET (Inter-ligation PET)                    │    │\n│  │                                                          │    │\n│  │  Distance ≤ 1000bp AND same chromosome?                  │    │\n│  │      YES → sPET (Self-ligation PET)                     │    │\n│  │                                                          │    │\n│  │  Different chromosomes?                                  │    │\n│  │      YES → iPET (Trans interaction)                     │    │\n│  │                                                          │    │\n│  │  Invalid orientation or unmapped?                        │    │\n│  │      YES → oPET (Other PET)                             │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Output:                                                         │\n│  ┌──────────────┐  ┌──────────────┐  ┌──────────────┐           │\n│  │ iPET         │  │ sPET         │  │ oPET         │           │\n│  │ (loops)      │  │ (peaks)      │  │ (discard)    │           │\n│  │ → Step 6     │  │ → Step 5     │  │              │           │\n│  └──────────────┘  └──────────────┘  └──────────────┘           │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n```\n\n### Code\n\n```python\n# =============================================================================\n# STEP 4: PET CATEGORIZATION\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 4: PET CATEGORIZATION\")\nprint(\"=\" * 70)\n\n# Initialize categorizer\n# Note: HiChIP uses 1kb cutoff (shorter than ChIA-PET's 8kb)\ncategorizer = PETCategorizer(\n    self_ligation_cutoff=1000,    # 1kb for HiChIP\n    mode='hichip'\n)\n\n# Run categorization\ncat_stats = categorizer.categorize_bedpe(\n    purified_bedpe,               # Input from Step 3\n    str(output_dir / 'step4_categorization/categorized')\n)\n\n# Print statistics\nprint(f\"Total PETs: {cat_stats['total']:,}\")\nprint(f\"iPETs: {cat_stats['ipet']['count']:,} ({cat_stats['ipet']['percentage']:.1f}%)\")\nprint(f\"sPETs: {cat_stats['spet']['count']:,} ({cat_stats['spet']['percentage']:.1f}%)\")\nprint(f\"oPETs: {cat_stats['opet']['count']:,} ({cat_stats['opet']['percentage']:.1f}%)\")\nprint(f\"Cis ratio: {cat_stats['cis']['percentage']:.1f}%\")\nprint(f\"Trans ratio: {cat_stats['trans']['percentage']:.1f}%\")\n\n# Define output files for next steps\nipet_file = str(output_dir / 'step4_categorization/categorized.ipet')\nspet_file = str(output_dir / 'step4_categorization/categorized.spet')\n```\n\n### Expected Output\n\n```\nSTEP 4: PET CATEGORIZATION\n======================================================================\nPETCategorizer initialized\n  Self-ligation cutoff: 1000bp\n  Mode: hichip\nProcessing PETs...\nTotal PETs: 43,492\niPETs: 24,771 (57.0%)\nsPETs: 385 (0.9%)\noPETs: 18,336 (42.1%)\nCis ratio: 85.3%\nTrans ratio: 14.7%\n```\n\n***\n\n## Step 5: Peak Calling\n\n### What This Step Does\n\nThe `PeakCaller` uses MACS3 to call enrichment peaks from self-ligation PETs (sPET). These peaks represent protein binding sites (e.g., H3K27ac marks for enhancers).\n\n### Code\n\n```python\n# =============================================================================\n# STEP 5: PEAK CALLING\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 5: PEAK CALLING\")\nprint(\"=\" * 70)\n\n# Initialize peak caller\npeak_caller = PeakCaller(\n    genome_size='hs',             # Human genome\n    qvalue_cutoff=0.05,           # Q-value threshold\n    keep_dup='all'                # Keep all reads (already deduplicated)\n)\n\n# Run peak calling\npeak_stats = peak_caller.call_peaks(\n    spet_file,                    # Input sPET from Step 4\n    str(output_dir / 'step5_peaks/peaks')\n)\n\n# Print statistics\nprint(f\"Peaks called: {peak_stats.get('num_peaks', 0):,}\")\nprint(f\"Peak file: {output_dir}/step5_peaks/peaks_peaks.narrowPeak\")\n```\n\n***\n\n## Step 6: Loop Calling\n\nThis is the most complex step, consisting of three sub-steps:\n\n### Step 6.1: Pre-Clustering\n\n### What This Step Does\n\nThe `PreClusterer` extends each PET tag by a specified length and creates initial cluster objects. This groups nearby interactions together.\n\n### ASCII Diagram: Pre-Clustering Logic\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│                    STEP 6.1: PRE-CLUSTERING                      │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  Tag Extension (extension_length = 500bp):                       │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  Original tag position:                                  │    │\n│  │       │                                                  │    │\n│  │       ▼                                                  │    │\n│  │  ─────●─────                                             │    │\n│  │                                                          │    │\n│  │  Forward strand (+): extend upstream                     │    │\n│  │  ◄────●                                                  │    │\n│  │  [pos-500, pos]                                          │    │\n│  │                                                          │    │\n│  │  Reverse strand (-): extend downstream                   │    │\n│  │       ●────►                                             │    │\n│  │  [pos, pos+500]                                          │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Creating Cluster Objects:                                       │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  iPET Entry:                                             │    │\n│  │  chr1:100000(+) ─────────────── chr1:200000(-)          │    │\n│  │                                                          │    │\n│  │  After Extension:                                        │    │\n│  │  [99500-100000] ─────────────── [200000-200500]         │    │\n│  │   (Anchor 1)                      (Anchor 2)             │    │\n│  │                                                          │    │\n│  │  Cluster Object:                                         │    │\n│  │  {chr1, 99500, 100000, chr1, 200000, 200500, weight=1}  │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Sort by chromosome and position, then merge overlapping         │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n```\n\n### Code\n\n```python\n# =============================================================================\n# STEP 6.1: PRE-CLUSTERING\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 6.1: PRE-CLUSTERING\")\nprint(\"=\" * 70)\n\n# Initialize pre-clusterer\npre_clusterer = PreClusterer(\n    extension_length=500          # Extend each tag by 500bp\n)\n\n# Run pre-clustering\nprecluster_stats = pre_clusterer.pre_cluster(\n    ipet_file,                    # Input iPET from Step 4\n    str(output_dir / 'step6_loops/preclustered')\n)\n\n# Print statistics\nprint(f\"Input iPETs: {precluster_stats.get('input_pets', 'N/A'):,}\")\nprint(f\"Pre-clusters created: {precluster_stats.get('cluster_count', 'N/A'):,}\")\nprint(f\"Output file: {precluster_stats.get('output_file', 'N/A')}\")\n\nprecluster_file = precluster_stats['output_file']\n```\n\n### Step 6.2: Anchor Clustering\n\n### What This Step Does\n\nThe `AnchorClusterer` merges overlapping pre-clusters into anchor clusters. Two clusters are merged if BOTH their head AND tail anchors overlap.\n\n### ASCII Diagram: Anchor Clustering Logic\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│                    STEP 6.2: ANCHOR CLUSTERING                   │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  Merging Rule: Both anchors must overlap                         │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  Cluster A:  [====]──────────────────[====]             │    │\n│  │              Anchor1                  Anchor2            │    │\n│  │                                                          │    │\n│  │  Cluster B:    [====]────────────────[====]             │    │\n│  │                Anchor1                Anchor2            │    │\n│  │                                                          │    │\n│  │  Both overlap? ✓ Head overlaps, ✓ Tail overlaps         │    │\n│  │  → MERGE into single cluster                             │    │\n│  │                                                          │    │\n│  │  Merged:     [======]────────────────[======]           │    │\n│  │              (union)                  (union)            │    │\n│  │              iPETs = A.iPETs + B.iPETs                   │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Non-Merging Case:                                               │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  Cluster A:  [====]──────────────────[====]             │    │\n│  │                                                          │    │\n│  │  Cluster C:    [====]────────────────────────[====]     │    │\n│  │                                                          │    │\n│  │  Head overlaps? ✓                                        │    │\n│  │  Tail overlaps? ✗                                        │    │\n│  │  → DO NOT MERGE (different interactions)                 │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Iterative Merging:                                              │\n│  Repeat until no more merges possible                            │\n│  Iteration 1: 1000 → 800 clusters                                │\n│  Iteration 2: 800 → 750 clusters                                 │\n│  Iteration 3: 750 → 750 clusters (done)                          │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n```\n\n### Code\n\n```python\n# =============================================================================\n# STEP 6.2: ANCHOR CLUSTERING\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 6.2: ANCHOR CLUSTERING\")\nprint(\"=\" * 70)\n\n# Initialize anchor clusterer\nanchor_clusterer = AnchorClusterer()\n\n# Run anchor clustering\ncluster_stats = anchor_clusterer.cluster_anchors(\n    precluster_file,              # Input from Step 6.1\n    str(output_dir / 'step6_loops/clusters.txt')\n)\n\n# Print statistics\nprint(f\"Input pre-clusters: {cluster_stats.get('num_preclusters', 'N/A'):,}\")\nprint(f\"Output anchor clusters: {cluster_stats.get('num_anchor_clusters', 'N/A'):,}\")\nprint(f\"Clusters merged: {cluster_stats.get('num_merged', 'N/A'):,}\")\n\ncluster_file = str(output_dir / 'step6_loops/clusters.txt')\n```\n\n### Step 6.3: Statistical Significance\n\n### What This Step Does\n\nThe `StatisticalSignificance` class calculates p-values for each loop using a distance-corrected Poisson model (for HiChIP) and applies Benjamini-Hochberg FDR correction.\n\n### ASCII Diagram: Statistical Testing\n\n```\n┌─────────────────────────────────────────────────────────────────┐\n│                    STEP 6.3: STATISTICAL SIGNIFICANCE            │\n├─────────────────────────────────────────────────────────────────┤\n│                                                                  │\n│  Distance-Corrected Model (HiChIP):                              │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  Contact frequency decays with distance:                 │    │\n│  │                                                          │    │\n│  │  Contacts                                                │    │\n│  │     │                                                    │    │\n│  │     │ ╲                                                  │    │\n│  │     │   ╲                                                │    │\n│  │     │     ╲___                                           │    │\n│  │     │         ╲___                                       │    │\n│  │     │             ╲___                                   │    │\n│  │     └─────────────────────────► Distance                 │    │\n│  │                                                          │    │\n│  │  Expected contacts = f(distance)                         │    │\n│  │  P-value = Poisson(observed, expected)                   │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  FDR Correction (Benjamini-Hochberg):                            │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │                                                          │    │\n│  │  1. Sort p-values: p₁ ≤ p₂ ≤ ... ≤ pₙ                   │    │\n│  │  2. Calculate adjusted p-value:                          │    │\n│  │     FDR_i = p_i × (n / i)                                │    │\n│  │  3. Filter: FDR &lt; 0.05                                   │    │\n│  │                                                          │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n│  Output:                                                         │\n│  ┌─────────────────────────────────────────────────────────┐    │\n│  │ loops.cluster.filtered      - All loops (iPET ≥ 2)      │    │\n│  │ loops.cluster.FDRfiltered   - Significant (FDR &lt; 0.05)  │    │\n│  └─────────────────────────────────────────────────────────┘    │\n│                                                                  │\n└─────────────────────────────────────────────────────────────────┘\n```\n\n### Code\n\n```python\n# =============================================================================\n# STEP 6.3: STATISTICAL SIGNIFICANCE\n# =============================================================================\nprint(\"=\" * 70)\nprint(\"STEP 6.3: STATISTICAL SIGNIFICANCE\")\nprint(\"=\" * 70)\n\n# Initialize statistical significance calculator\n# IMPORTANT: use_distance_correction=True for HiChIP\nstat_sig = StatisticalSignificance(\n    ipet_count_threshold=2,       # Minimum iPET count\n    pvalue_cutoff=0.05,           # FDR threshold\n    extension_length=500,         # Must match pre-clustering\n    use_distance_correction=True  # ENABLE for HiChIP!\n)\n\n# Run significance testing\nsig_stats = stat_sig.calculate_significance(\n    cluster_file,                 # Input from Step 6.2\n    ipet_file,                    # Original iPET file for tag counting\n    str(output_dir / 'step6_loops/loops')\n)\n\n# Print statistics\nprint(f\"Total loops tested: {sig_stats.get('total_loops', 'N/A'):,}\")\nprint(f\"Significant loops (FDR &lt; 0.05): {sig_stats.get('significant_loops', 'N/A'):,}\")\nprint(f\"Output: {output_dir}/step6_loops/loops.cluster.FDRfiltered.txt\")\n```\n\n***\n\n## Complete Pipeline Script\n\nHere's the complete script combining all steps:\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nComplete HiChIP Analysis Pipeline using Chr3D Python API\n\"\"\"\n\nimport sys\nimport logging\nfrom pathlib import Path\n\nsys.path.insert(0, '/path/to/Chr3D/src')\n\nfrom chr3d.mapping_v2 import PETMapper\nfrom chr3d.hichip_purifying import HiChIPPurifier\nfrom chr3d.pet_categorization import PETCategorizer\nfrom chr3d.peak_calling import PeakCaller\nfrom chr3d.loop_calling import PreClusterer, AnchorClusterer, StatisticalSignificance\n\n# Setup logging\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\ndef run_hichip_pipeline(\n    fastq_r1: str,\n    fastq_r2: str,\n    genome_index: str,\n    restriction_sites: str,\n    output_dir: str,\n    threads: int = 8\n):\n    \"\"\"Run complete HiChIP pipeline.\"\"\"\n    \n    output_dir = Path(output_dir)\n    output_dir.mkdir(parents=True, exist_ok=True)\n    \n    # Create step directories\n    for step in ['step2_mapping', 'step3_purifying', 'step4_categorization',\n                 'step5_peaks', 'step6_loops']:\n        (output_dir / step).mkdir(exist_ok=True)\n    \n    # Step 2: Mapping\n    mapper = PETMapper(genome_index=genome_index, n_threads=threads, use_bwa_mem=True)\n    mapper.map_linker_filtered_fastq(fastq_r1, fastq_r2, 'mapped',\n                                      str(output_dir / 'step2_mapping'))\n    \n    # Step 3: Purifying\n    purifier = HiChIPPurifier(restriction_file=restriction_sites)\n    purifier.remove_same_fragment_pets(\n        str(output_dir / 'step2_mapping/mapped.dedup.bedpe'),\n        str(output_dir / 'step3_purifying/purified.valid.bedpe'),\n        str(output_dir / 'step3_purifying/purified.sameres.bedpe')\n    )\n    \n    # Step 4: Categorization\n    categorizer = PETCategorizer(self_ligation_cutoff=1000, mode='hichip')\n    categorizer.categorize_bedpe(\n        str(output_dir / 'step3_purifying/purified.valid.bedpe'),\n        str(output_dir / 'step4_categorization/categorized')\n    )\n    \n    # Step 5: Peak Calling\n    peak_caller = PeakCaller(genome_size='hs')\n    peak_caller.call_peaks(\n        str(output_dir / 'step4_categorization/categorized.spet'),\n        str(output_dir / 'step5_peaks/peaks')\n    )\n    \n    # Step 6: Loop Calling\n    pre_clusterer = PreClusterer(extension_length=500)\n    precluster_stats = pre_clusterer.pre_cluster(\n        str(output_dir / 'step4_categorization/categorized.ipet'),\n        str(output_dir / 'step6_loops/preclustered')\n    )\n    \n    anchor_clusterer = AnchorClusterer()\n    anchor_clusterer.cluster_anchors(\n        precluster_stats['output_file'],\n        str(output_dir / 'step6_loops/clusters.txt')\n    )\n    \n    stat_sig = StatisticalSignificance(use_distance_correction=True)\n    stat_sig.calculate_significance(\n        str(output_dir / 'step6_loops/clusters.txt'),\n        str(output_dir / 'step4_categorization/categorized.ipet'),\n        str(output_dir / 'step6_loops/loops')\n    )\n    \n    print(f\"Pipeline complete! Results in: {output_dir}\")\n\nif __name__ == '__main__':\n    run_hichip_pipeline(\n        fastq_r1='/data/sample_R1.fastq.gz',\n        fastq_r2='/data/sample_R2.fastq.gz',\n        genome_index='/ref/hg38.fa',\n        restriction_sites='/ref/hg38_MboI_sites.bed',\n        output_dir='/output/hichip_results',\n        threads=8\n    )\n```\n\n***\n\n## Final Output Format\n\n### Significant Loops File (loops.cluster.FDRfiltered.txt)\n\n```\nchr1    100000    100500    chr1    200000    200500    5    2.3    100000    0.001    0.023\nchr1    300000    300500    chr1    450000    450500    8    3.1    150000    0.0001   0.005\n```\n\n| Column | Description                         |\n| ------ | ----------------------------------- |\n| 1-3    | Anchor 1: chr, start, end           |\n| 4-6    | Anchor 2: chr, start, end           |\n| 7      | iPET count                          |\n| 8      | Expected count (distance-corrected) |\n| 9      | Distance between anchors            |\n| 10     | Raw p-value                         |\n| 11     | FDR (adjusted p-value)              |\n\n***\n\n## See Also\n\n* [HiChIP CLI Tutorial](./hichip-cli) - Command-line interface version\n* [HiChIP API Reference](../api/hichip) - Detailed API documentation\n* [Hi-C API Tutorial](./hic-api) - Hi-C analysis tutorial\n";
