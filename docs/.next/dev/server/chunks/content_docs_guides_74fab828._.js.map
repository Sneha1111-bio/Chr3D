import {Fragment as _Fragment, jsx as _jsx, jsxs as _jsxs} from "react/jsx-runtime";
export let _markdown = "\n\n## Loop Calling Methods\n\nChromatin loops are focal enrichments in contact matrices representing stable physical interactions between genomic loci.\n\n## Method Overview\n\n| Method            | Best For             | Resolution | Computational Cost |\n| ----------------- | -------------------- | ---------- | ------------------ |\n| **HiCCUPS**       | Hi-C loops           | 5-10kb     | High               |\n| **HiChIPper**     | HiChIP loops         | 5-10kb     | Medium             |\n| **ChIA-PET Tool** | ChIA-PET clusters    | Variable   | Low                |\n| **Fit-Hi-C**      | Significant contacts | 10-40kb    | Medium             |\n\n## Hi-C Loop Calling\n\n### HiCCUPS Algorithm\n\n```python\nfrom chr3d import HiC\n\n# Load normalized Hi-C data\nhic = HiC.from_cooler(\"sample.cool\")\nhic_norm = hic.normalize(method=\"KR\")\n\n# Call loops with HiCCUPS\nloops = hic_norm.call_loops(\n    method=\"hiccups\",\n    resolution=10000,\n    fdr=0.1,\n    min_distance=20000,\n    max_distance=2000000\n)\n\nprint(f\"Called {len(loops):,} loops\")\n```\n\n**Parameters:**\n\n* **resolution:** 5kb or 10kb recommended\n* **fdr:** 0.1 (permissive) to 0.01 (stringent)\n* **min\\_distance:** Typically 20kb (avoid self-ligation artifacts)\n* **max\\_distance:** 2Mb (most loops are \\<2Mb)\n\n### Filtering Loops\n\n```python\n# Filter by enrichment\nloops_high_conf = loops[loops['enrichment'] > 2.0]\n\n# Filter by statistical significance\nloops_sig = loops[loops['qvalue'] < 0.01]\n\n# Filter by distance\nloops_filtered = loops[\n    (loops['distance'] > 20000) & \n    (loops['distance'] < 1000000)\n]\n\nprint(f\"High-confidence loops: {len(loops_high_conf):,}\")\n```\n\n## HiChIP Loop Calling\n\n### HiChIPper Algorithm\n\n```python\nfrom chr3d import HiChIP\n\n# Load HiChIP data\nhichip = HiChIP.from_pairs(\"sample.pairs.gz\")\n\n# Call loops with HiChIPper\nloops = hichip.call_loops(\n    method=\"hichipper\",\n    resolution=10000,\n    fdr=0.01,\n    min_distance=5000,\n    max_distance=2000000,\n    merge_distance=15000  # Merge nearby loops\n)\n\nprint(f\"Called {len(loops):,} loops\")\n```\n\n**HiChIP-Specific Parameters:**\n\n* **fdr:** 0.01 recommended (HiChIP has better signal-to-noise)\n* **merge\\_distance:** 15kb (merge redundant calls)\n* **min\\_distance:** 5kb (HiChIP can detect shorter loops)\n\n### Peak-Anchored Calling\n\n```python\nfrom chr3d.utils import load_peaks\n\n# Load ChIP-seq peaks\npeaks = load_peaks(\"H3K27ac_peaks.bed\")\n\n# Require both anchors at peaks\nloops_anchored = hichip.call_loops(\n    method=\"hichipper\",\n    peaks=peaks,\n    require_both_anchors=True,\n    fdr=0.01\n)\n\nprint(f\"Peak-anchored loops: {len(loops_anchored):,}\")\n```\n\n## ChIA-PET Loop Calling\n\n### PET Cluster Method\n\n```python\nfrom chr3d import ChIAPET\n\n# Load ChIA-PET data\nchiapet = ChIAPET.from_bedpe(\"sample.bedpe\")\n\n# Call loops based on PET clusters\nloops = chiapet.call_loops(\n    min_pets=3,  # Minimum PETs per cluster\n    peak_mode=True,  # Require anchor peaks\n    fdr=0.01\n)\n\nprint(f\"Called {len(loops):,} PET clusters\")\n```\n\n**Parameters:**\n\n* **min\\_pets:** 2 (permissive), 3 (standard), 5+ (stringent)\n* **peak\\_mode:** True (requires peaks at anchors)\n* **extension:** Peak extension distance (default: 500bp)\n\n### Peak Calling First\n\n```python\n# Call peaks at interaction anchors\npeaks = chiapet.call_peaks(\n    method=\"macs2\",\n    genome=\"hg38\",\n    qvalue=0.01\n)\n\n# Then call loops with peak requirement\nloops = chiapet.call_loops(\n    min_pets=3,\n    peaks=peaks,\n    peak_mode=True\n)\n\nprint(f\"Peaks: {len(peaks)}, Loops: {len(loops)}\")\n```\n\n## Validation Methods\n\n### Aggregate Peak Analysis (APA)\n\n```python\n# Compute APA score\napa = hic_norm.compute_apa(\n    loops=loops,\n    window=200000,\n    resolution=10000\n)\n\nprint(f\"APA score: {apa['score']:.2f}\")\n\n# Plot APA\nhic_norm.plot_apa(apa)\nplt.savefig(\"apa.png\", dpi=300)\n```\n\n**Interpretation:**\n\n* **APA > 1.5:** Strong loop enrichment\n* **APA 1.2-1.5:** Moderate enrichment\n* **APA \\< 1.2:** Weak or no enrichment\n\n### Motif Enrichment (CTCF)\n\n```python\n# For CTCF-mediated loops\nloops_with_motifs = loops.add_motif_orientation(\n    motif=\"CTCF\",\n    genome=\"hg38\"\n)\n\n# Check convergent orientation\nconvergent = loops_with_motifs[\n    loops_with_motifs['motif_orientation'] == 'convergent'\n]\n\nprint(f\"Convergent CTCF loops: {len(convergent)/len(loops_with_motifs)*100:.1f}%\")\n# Expected: 80-90% for CTCF loops\n```\n\n### Reproducibility Between Replicates\n\n```python\n# Load replicates\nrep1_loops = hic1.call_loops(method=\"hiccups\", fdr=0.1)\nrep2_loops = hic2.call_loops(method=\"hiccups\", fdr=0.1)\n\n# Compute overlap\noverlap = rep1_loops.overlap(rep2_loops, max_distance=20000)\n\nprint(f\"Reproducible loops: {len(overlap):,}\")\nprint(f\"Reproducibility: {len(overlap)/len(rep1_loops)*100:.1f}%\")\n# Expected: >60% for good replicates\n```\n\n## Advanced Filtering\n\n### Distance-Based Filtering\n\n```python\n# Remove very short-range (&lt;10kb)\nloops_filtered = loops[loops['distance'] > 10000]\n\n# Focus on specific distance range\nenhancer_promoter = loops[\n    (loops['distance'] > 10000) & \n    (loops['distance'] < 500000)\n]\n```\n\n### Genomic Feature Filtering\n\n```python\n# Annotate with genomic features\nloops_annotated = loops.annotate_genes(\n    gtf=\"gencode.v38.annotation.gtf\",\n    promoter_window=2000\n)\n\n# Keep only promoter-involved loops\npromoter_loops = loops_annotated[\n    (loops_annotated['anchor1_feature'] == 'promoter') |\n    (loops_annotated['anchor2_feature'] == 'promoter')\n]\n\nprint(f\"Promoter loops: {len(promoter_loops):,}\")\n```\n\n### Blacklist Removal\n\n```python\n# Remove loops in problematic regions\nloops_clean = loops.remove_blacklist(genome=\"hg38\")\n\nprint(f\"After blacklist removal: {len(loops_clean):,}\")\n```\n\n## Multi-Resolution Loop Calling\n\n```python\n# Call loops at multiple resolutions\nresolutions = [5000, 10000, 25000]\nall_loops = []\n\nfor res in resolutions:\n    hic_res = HiC.from_cooler(f\"sample.mcool::resolutions/{res}\")\n    hic_res_norm = hic_res.normalize(method=\"KR\")\n    \n    loops_res = hic_res_norm.call_loops(\n        method=\"hiccups\",\n        resolution=res,\n        fdr=0.1\n    )\n    \n    all_loops.append(loops_res)\n    print(f\"{res/1000:.0f}kb: {len(loops_res):,} loops\")\n\n# Merge loops across resolutions\nmerged_loops = merge_multi_resolution_loops(all_loops)\n```\n\n## Differential Loop Analysis\n\n```python\n# Compare conditions\nloops_treatment = hic_treatment.call_loops(method=\"hiccups\", fdr=0.1)\nloops_control = hic_control.call_loops(method=\"hiccups\", fdr=0.1)\n\n# Differential analysis\ndiff_loops = hic_treatment.differential_loops(\n    loops_treatment=loops_treatment,\n    loops_control=loops_control,\n    method=\"deseq2\"\n)\n\n# Significant changes\nsig_diff = diff_loops[\n    (diff_loops['padj'] < 0.05) & \n    (abs(diff_loops['log2fc']) > 1)\n]\n\nprint(f\"Gained loops: {len(sig_diff[sig_diff['log2fc'] > 0])}\")\nprint(f\"Lost loops: {len(sig_diff[sig_diff['log2fc'] < 0])}\")\n```\n\n## Best Practices\n\n### 1. Use Appropriate Resolution\n\n* **5kb:** High-resolution, requires >1B reads\n* **10kb:** Standard, requires >500M reads\n* **25kb:** Lower resolution, requires >200M reads\n\n### 2. Normalize Before Calling\n\n```python\n# Always normalize first\nhic_norm = hic.normalize(method=\"KR\")\nloops = hic_norm.call_loops(method=\"hiccups\")\n```\n\n### 3. Validate Results\n\n```python\n# Check APA score\napa = hic_norm.compute_apa(loops=loops)\nassert apa['score'] > 1.2, \"Weak loop enrichment\"\n\n# Check reproducibility\n# (compare with replicate)\n```\n\n### 4. Filter Stringently\n\n```python\n# Multi-step filtering\nloops_final = (loops\n    .query('qvalue < 0.01')\n    .query('enrichment > 2.0')\n    .query('distance > 20000')\n    .query('distance < 2000000')\n)\n```\n\n## Troubleshooting\n\n### Few Loops Called\n\n**Causes:**\n\n* Insufficient sequencing depth\n* Poor data quality\n* Too stringent parameters\n\n**Solutions:**\n\n```python\n# Try more permissive FDR\nloops = hic_norm.call_loops(method=\"hiccups\", fdr=0.2)\n\n# Lower distance threshold\nloops = hic_norm.call_loops(min_distance=10000)\n\n# Check data quality\nqc = hic.qc_report()\n```\n\n### Too Many Loops\n\n**Causes:**\n\n* Too permissive parameters\n* Poor normalization\n* High background noise\n\n**Solutions:**\n\n```python\n# More stringent FDR\nloops = hic_norm.call_loops(method=\"hiccups\", fdr=0.01)\n\n# Filter by enrichment\nloops = loops[loops['enrichment'] > 3.0]\n\n# Check normalization\nhic_norm.plot_matrix(\"chr1\")  # Should look smooth\n```\n\n### Low APA Score\n\n**Causes:**\n\n* False positive loops\n* Poor resolution\n* Technical artifacts\n\n**Solutions:**\n\n```python\n# Use higher resolution\nhic_5kb = HiC.from_cooler(\"sample.mcool::resolutions/5000\")\n\n# More stringent filtering\nloops = loops[loops['qvalue'] < 0.001]\n```\n\n## Export Results\n\n```python\n# Export to standard formats\nloops.to_bedpe(\"loops.bedpe\")\nloops.to_bed(\"loops.bed\")  # Converts to 1D regions\n\n# Export with annotations\nloops_annotated.to_csv(\"loops_annotated.csv\")\n\n# Export for visualization\nloops.to_ucsc_track(\"loops.bb\", genome=\"hg38\")\n```\n";
