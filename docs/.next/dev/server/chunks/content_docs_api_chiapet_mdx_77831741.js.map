import {Fragment as _Fragment, jsx as _jsx, jsxs as _jsxs} from "react/jsx-runtime";
export let _markdown = "\n\n# ChIA-PET Python API\n\nComplete Python API for analyzing ChIA-PET (Chromatin Interaction Analysis by Paired-End Tag sequencing) data.\n\n## Overview\n\nChIA-PET analysis requires these modules:\n\n* `LinkerFilterV3` - Linker detection and filtering\n* `PETMapper` - Read mapping\n* `ChIAPETPurifier` - Duplicate removal and merging\n* `PETCategorizer` - PET classification\n* `PeakCaller` - Peak calling from sPET\n* `PreClusterer`, `AnchorClusterer`, `StatisticalSignificance` - Loop calling\n\n## Complete Pipeline Example\n\n```python\nimport sys\nsys.path.insert(0, '/path/to/Chr3D/src')\n\nfrom pathlib import Path\nfrom chr3d.linker_filtering_v3 import LinkerFilterV3\nfrom chr3d.mapping_v2 import PETMapper\nfrom chr3d.chiapet_purifying import ChIAPETPurifier\nfrom chr3d.pet_categorization import PETCategorizer\nfrom chr3d.peak_calling import PeakCaller\nfrom chr3d.loop_calling import PreClusterer, AnchorClusterer, StatisticalSignificance\n\n# Configuration\nfastq_r1 = \"/data/sample_R1.fastq.gz\"\nfastq_r2 = \"/data/sample_R2.fastq.gz\"\ngenome_index = \"/ref/hg38.fa\"\noutput_dir = Path(\"/output/chiapet_analysis\")\noutput_dir.mkdir(parents=True, exist_ok=True)\n\n# =============================================================================\n# STEP 1: LINKER FILTERING\n# =============================================================================\nlinker_filter = LinkerFilterV3(\n    linker_sequences=['ACGCGATATCTTATCTGACT', 'AGTCAGATAAGATATCGCGT'],\n    min_alignment_score=14,\n    min_tag_length=18,\n    max_tag_length=1000,\n    n_threads=8\n)\n\nlinker_stats = linker_filter.filter_fastq_parallel(\n    fastq_r1=fastq_r1,\n    fastq_r2=fastq_r2,\n    output_prefix='filtered',\n    output_dir=str(output_dir / 'step1_linker')\n)\n\nprint(f\"Valid PETs after linker filtering: {linker_stats['valid_pets']:,}\")\n\n# =============================================================================\n# STEP 2: GENOMIC MAPPING\n# =============================================================================\nmapper = PETMapper(\n    genome_index=genome_index,\n    mapping_quality_cutoff=30,\n    n_threads=8,\n    use_bwa_mem=True,\n    self_ligation_cutoff=8000\n)\n\n# Use filtered FASTQ files\nfiltered_r1 = str(output_dir / 'step1_linker/filtered.1_1.R1.fastq')\nfiltered_r2 = str(output_dir / 'step1_linker/filtered.1_1.R2.fastq')\n\nmap_stats = mapper.map_linker_filtered_fastq(\n    fastq_r1=filtered_r1,\n    fastq_r2=filtered_r2,\n    output_prefix='mapped',\n    output_dir=str(output_dir / 'step2_mapping'),\n    keep_sam=False,\n    remove_duplicates=True\n)\n\nprint(f\"Unique PETs: {map_stats.get('unique_pets', 'N/A'):,}\")\n\n# =============================================================================\n# STEP 3: PET PURIFYING\n# =============================================================================\npurifier = ChIAPETPurifier(merge_distance=2)\n\nbedpe_file = str(output_dir / 'step2_mapping/mapped.dedup.bedpe')\npurify_stats = purifier.purify(\n    bedpe_file,\n    str(output_dir / 'step3_purifying/purified')\n)\n\npurified_bedpe = str(output_dir / 'step3_purifying/purified.merged.bedpe')\n\n# =============================================================================\n# STEP 4: PET CATEGORIZATION\n# =============================================================================\ncategorizer = PETCategorizer(\n    self_ligation_cutoff=8000,  # 8kb for ChIA-PET\n    mode='chiapet'\n)\n\ncat_stats = categorizer.categorize_bedpe(\n    purified_bedpe,\n    str(output_dir / 'step4_categorization/categorized')\n)\n\nprint(f\"iPETs: {cat_stats['ipet']['count']:,}\")\nprint(f\"sPETs: {cat_stats['spet']['count']:,}\")\n\nipet_file = str(output_dir / 'step4_categorization/categorized.ipet')\nspet_file = str(output_dir / 'step4_categorization/categorized.spet')\n\n# =============================================================================\n# STEP 5: PEAK CALLING\n# =============================================================================\npeak_caller = PeakCaller(\n    genome_size='hs',\n    qvalue_cutoff=0.05,\n    keep_dup='all'\n)\n\npeak_stats = peak_caller.call_peaks(\n    spet_file,\n    str(output_dir / 'step5_peaks/peaks')\n)\n\nprint(f\"Peaks called: {peak_stats.get('num_peaks', 0):,}\")\n\n# =============================================================================\n# STEP 6: LOOP CALLING\n# =============================================================================\n\n# Step 6.1: Pre-clustering\npre_clusterer = PreClusterer(extension_length=500)\nprecluster_stats = pre_clusterer.pre_cluster(\n    ipet_file,\n    str(output_dir / 'step6_loops/preclustered')\n)\n\n# Step 6.2: Anchor clustering\nanchor_clusterer = AnchorClusterer()\ncluster_stats = anchor_clusterer.cluster_anchors(\n    precluster_stats['output_file'],\n    str(output_dir / 'step6_loops/clusters.txt')\n)\n\n# Step 6.3: Statistical significance\nstat_sig = StatisticalSignificance(\n    ipet_count_threshold=2,\n    pvalue_cutoff=0.05,\n    extension_length=500,\n    use_distance_correction=False  # Standard Poisson for ChIA-PET\n)\n\nsig_stats = stat_sig.calculate_significance(\n    str(output_dir / 'step6_loops/clusters.txt'),\n    ipet_file,\n    str(output_dir / 'step6_loops/loops')\n)\n\nprint(f\"Significant loops: {sig_stats.get('significant_loops', 0):,}\")\n```\n\n## Module Reference\n\n### LinkerFilterV3\n\nHigh-performance linker filtering using Smith-Waterman alignment.\n\n```python\nfrom chr3d.linker_filtering_v3 import LinkerFilterV3\n\nfilter = LinkerFilterV3(\n    linker_sequences: List[str],      # Linker sequences to detect\n    min_alignment_score: int = 14,    # Minimum alignment score\n    min_tag_length: int = 18,         # Minimum tag length after trimming\n    max_tag_length: int = 1000,       # Maximum tag length\n    n_threads: int = 1                # Number of threads\n)\n\n# Main method\nstats = filter.filter_fastq_parallel(\n    fastq_r1: str,           # Input R1 FASTQ\n    fastq_r2: str,           # Input R2 FASTQ\n    output_prefix: str,      # Output file prefix\n    output_dir: str          # Output directory\n) -> Dict\n```\n\n**Returns:**\n\n```python\n{\n    'total_reads': int,\n    'valid_pets': int,\n    'linker_1_1': int,  # Both reads have linker A\n    'linker_2_2': int,  # Both reads have linker B\n    'linker_1_2': int,  # Chimeric\n    'no_linker': int\n}\n```\n\n### PETMapper\n\nBWA-based read mapping with BEDPE generation.\n\n```python\nfrom chr3d.mapping_v2 import PETMapper\n\nmapper = PETMapper(\n    genome_index: str,                    # BWA-indexed genome\n    mapping_quality_cutoff: int = 30,     # Min MAPQ\n    n_threads: int = 1,                   # Threads\n    use_bwa_mem: bool = False,            # Use BWA-MEM vs BWA-ALN\n    self_ligation_cutoff: int = 8000      # Self-ligation distance\n)\n\n# Main method\nstats = mapper.map_linker_filtered_fastq(\n    fastq_r1: str,\n    fastq_r2: str,\n    output_prefix: str,\n    output_dir: str = None,\n    keep_sam: bool = False,\n    remove_duplicates: bool = True\n) -> Dict\n```\n\n### ChIAPETPurifier\n\nRemoves duplicates and merges overlapping PETs.\n\n```python\nfrom chr3d.chiapet_purifying import ChIAPETPurifier\n\npurifier = ChIAPETPurifier(\n    merge_distance: int = 2    # Max distance for merging\n)\n\nstats = purifier.purify(\n    input_bedpe: str,\n    output_prefix: str\n) -> Dict\n```\n\n### PETCategorizer\n\nClassifies PETs into categories.\n\n```python\nfrom chr3d.pet_categorization import PETCategorizer\n\ncategorizer = PETCategorizer(\n    self_ligation_cutoff: int = 8000,  # Distance cutoff\n    mode: str = 'chiapet'              # 'chiapet' or 'hichip'\n)\n\nstats = categorizer.categorize_bedpe(\n    input_bedpe: str,\n    output_prefix: str\n) -> Dict\n```\n\n**Returns:**\n\n```python\n{\n    'total': int,\n    'ipet': {'count': int, 'percentage': float},\n    'spet': {'count': int, 'percentage': float},\n    'opet': {'count': int, 'percentage': float},\n    'cis': {'count': int, 'percentage': float},\n    'trans': {'count': int, 'percentage': float}\n}\n```\n\n### PeakCaller\n\nMACS3-based peak calling.\n\n```python\nfrom chr3d.peak_calling import PeakCaller\n\ncaller = PeakCaller(\n    genome_size: str = 'hs',       # 'hs', 'mm', or number\n    qvalue_cutoff: float = 0.05,   # Q-value threshold\n    keep_dup: str = 'all'          # Duplicate handling\n)\n\nstats = caller.call_peaks(\n    input_file: str,\n    output_prefix: str\n) -> Dict\n```\n\n### Loop Calling Classes\n\n#### PreClusterer\n\n```python\nfrom chr3d.loop_calling import PreClusterer\n\nclusterer = PreClusterer(\n    extension_length: int = 500,        # Tag extension\n    chrom_sizes_file: str = None        # Optional chrom sizes\n)\n\nstats = clusterer.pre_cluster(\n    ipet_file: str,\n    output_prefix: str\n) -> Dict\n```\n\n#### AnchorClusterer\n\n```python\nfrom chr3d.loop_calling import AnchorClusterer\n\nclusterer = AnchorClusterer()\n\nstats = clusterer.cluster_anchors(\n    precluster_file: str,\n    output_file: str\n) -> Dict\n```\n\n#### StatisticalSignificance\n\n```python\nfrom chr3d.loop_calling import StatisticalSignificance\n\nsig = StatisticalSignificance(\n    ipet_count_threshold: int = 2,      # Min iPET count\n    pvalue_cutoff: float = 0.05,        # P-value threshold\n    extension_length: int = 500,        # Extension for counting\n    use_distance_correction: bool = False  # Distance correction (HiChIP)\n)\n\nstats = sig.calculate_significance(\n    cluster_file: str,\n    ipet_file: str,\n    output_prefix: str\n) -> Dict\n```\n\n## Output Files\n\n| File                            | Description              |\n| ------------------------------- | ------------------------ |\n| `filtered.*.R1.fastq`           | Linker-filtered R1 reads |\n| `filtered.*.R2.fastq`           | Linker-filtered R2 reads |\n| `mapped.dedup.bedpe`            | Deduplicated mapped PETs |\n| `purified.merged.bedpe`         | Merged PETs              |\n| `categorized.ipet`              | Inter-ligation PETs      |\n| `categorized.spet`              | Self-ligation PETs       |\n| `peaks_peaks.narrowPeak`        | Called peaks             |\n| `loops.cluster.FDRfiltered.txt` | Significant loops        |\n\n## Common Linker Sequences\n\n| Protocol      | Linker A               | Linker B               |\n| ------------- | ---------------------- | ---------------------- |\n| ChIA-PET Tool | `ACGCGATATCTTATCTGACT` | `AGTCAGATAAGATATCGCGT` |\n| ENCODE        | `GTTGGATAAG`           | `GTTGGAATGT`           |\n";
